[Unit]
Description=DEM MAVLink Router
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/dem/pi.env
ExecStart=/usr/local/bin/dem-mavlink-router-start.sh
Restart=always
RestartSec=2
User=pi
Group=pi
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
