# Copy to /etc/dem/pi.env and adjust values for your deployment.

# Ground control endpoint
GCS_HOST=192.168.1.50
GCS_UDP_PORT=14550
LOCAL_UDP_PORT=14551

# Telemetry device
PX4_UART_DEVICE=/dev/ttyAMA0

# PX4 UART
PX4_BAUD=115200

# Camera stream destination
VIDEO_HOST=192.168.1.50
VIDEO_PORT=5600

# Camera profile
CAM_WIDTH=1280
CAM_HEIGHT=720
CAM_FPS=30

# Phone-link backhaul (optional)
PHONE_LINK_ENABLE=0
PHONE_LINK_REQUIRED=0
PHONE_LINK_INTERFACE=wlan0
PHONE_LINK_GATEWAY=192.168.137.1
PHONE_LINK_PING_GATEWAY=1

# Logs and health checks
DEM_LOG_DIR=/var/log/dem
HEALTHCHECK_ENABLE=1
HEALTHCHECK_EXPECT_MAVLINK_ROUTER=1
HEALTHCHECK_EXPECT_CAMERA_STREAM=1
HEALTHCHECK_EXPECT_VIDEO_PORT=5600
